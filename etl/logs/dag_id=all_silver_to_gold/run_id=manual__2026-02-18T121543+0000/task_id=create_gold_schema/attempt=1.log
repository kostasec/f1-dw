 INTEGER,\n            driver_number               INTEGER,\n            grid                        INTEGER,\n            position                    FLOAT,\n            position_text               TEXT,\n            position_order              INTEGER,\n            points                      FLOAT,\n            number_of_laps              INTEGER,\n            rank                        FLOAT,\n            race_duration_hours         TEXT,\n            race_duration_milliseconds  FLOAT,\n            fastest_lap                 FLOAT,\n            fastest_lap_minutes         TEXT,\n            fastest_lap_speed           FLOAT,\n            status                      TEXT,\n            created_at                  TIMESTAMP,\n            source                      TEXT\n        );\n\n        CREATE TABLE facts.laps (\n            lap_key             INTEGER PRIMARY KEY,\n            race_key            INTEGER REFERENCES dimensions.race(race_key),\n            lap                 INTEGER,\n            driver_key          INTEGER REFERENCES dimensions.driver(driver_key),\n            constructor_key     INTEGER REFERENCES dimensions.constructor(constructor_key),\n            time_key            INTEGER REFERENCES dimensions.time(time_key),\n            lap_position        INTEGER,\n            lap_minutes         TEXT,\n            lap_milliseconds    FLOAT,\n            created_at          TIMESTAMP,\n            source              TEXT\n        );\n\n        CREATE TABLE facts.pitstops (\n            pitstop_key                     INTEGER PRIMARY KEY,\n            race_key                        INTEGER REFERENCES dimensions.race(race_key),\n            driver_key                      INTEGER REFERENCES dimensions.driver(driver_key),\n            stop                            INTEGER,\n            constructor_key                 INTEGER REFERENCES dimensions.constructor(constructor_key),\n            time_key                        INTEGER REFERENCES dimensions.time(time_key),\n            lap                             INTEGER,\n            local_time                      TEXT,\n            pitlane_duration_seconds        FLOAT,\n            pitlane_duration_milliseconds   FLOAT,\n            created_at                      TIMESTAMP,\n            source                          TEXT\n        );\n\n        CREATE TABLE facts.driver_standings (\n            ds_key          INTEGER PRIMARY KEY,\n            ds_id           INTEGER,\n            race_key        INTEGER REFERENCES dimensions.race(race_key),\n            driver_key      INTEGER REFERENCES dimensions.driver(driver_key),\n            constructor_key INTEGER REFERENCES dimensions.constructor(constructor_key),\n            time_key        INTEGER REFERENCES dimensions.time(time_key),\n            ds_points       FLOAT,\n            ds_position     FLOAT,\n            ds_wins         FLOAT,\n            created_at      TIMESTAMP,\n            source          TEXT\n        );\n\n        CREATE TABLE facts.constructor_standings (\n            cs_key          INTEGER PRIMARY KEY,\n            cs_id           INTEGER,\n            race_key        INTEGER REFERENCES dimensions.race(race_key),\n            constructor_key INTEGER REFERENCES dimensions.constructor(constructor_key),\n            time_key        INTEGER REFERENCES dimensions.time(time_key),\n            cs_points       FLOAT,\n            cs_position     FLOAT,\n            cs_wins         FLOAT,\n            created_at      TIMESTAMP,\n            source          TEXT\n        );\n\n        -- ═══════════════════════════════════════\n        -- INDEXES\n        -- ═══════════════════════════════════════\n        CREATE INDEX idx_results_race_key        ON facts.race_results(race_key);\n        CREATE INDEX idx_results_driver_key      ON facts.race_results(driver_key);\n        CREATE INDEX idx_results_constructor_key ON facts.race_results(constructor_key);\n        CREATE INDEX idx_results_time_key  